<Window x:Class="Defuser_Imitation_Updater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Defuser_Imitation_Updater"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Title="Defuser_Imitation_Updater"  Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FF1E1E1E" Height="40" Name="Header">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="MinimizeBtn" Style="{StaticResource MinimizeWindowButton}" Height="40" Width="40" Click="MinButton_Click"/>
                <Button Name="CloseBtn" Style="{StaticResource CloseWindowButton}" Height="40" Width="40" Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
        <Canvas Grid.Row="1" Name="MapCanvas">
            <Canvas.Background>
                <ImageBrush ImageSource="/Resources/world_map_background.jpg" Stretch="UniformToFill"/>
            </Canvas.Background>
            <Canvas.BitmapEffect>
                <BlurBitmapEffect Radius="10"/>
            </Canvas.BitmapEffect>
        </Canvas>
        <StackPanel Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0 0 0 30">
            <TextBlock FontFamily="{StaticResource RobotoMonoFont}" Text="DEFUSER" FontSize="90" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock FontFamily="{StaticResource RobotoMonoFont}" Text="IMITATION" FontSize="50" Foreground="White" HorizontalAlignment="Center" Margin="0 -15 0 0"/>
        </StackPanel>
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" >
            <TextBlock Name="TbState" FontFamily="{StaticResource RobotoMonoFont}" Foreground="White" FontSize="20" Margin="10 0 0 0"/>
            <ProgressBar Name="PbUpdate" Height="12" Foreground="#FF2BA1E7" Value="0"/>
        </StackPanel>
    </Grid>
</Window>
